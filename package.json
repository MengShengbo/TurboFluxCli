{
  "name": "turboflux",
  "version": "0.1.5",
  "description": "TurboFlux CLI - local AI workbench assistant for developer workflows",
  "main": "dist/cli/index.js",
  "bin": {
    "turboflux": "./bin/turboflux.mjs"
  },
  "author": "TurboFlux",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:cli",
    "dev:cli": "tsx watch src/cli/index.ts",
    "dev:once": "tsx src/cli/index.ts",
    "start": "tsx src/cli/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "benchmark:fast-context": "tsx scripts/retrieval-benchmark.ts",
    "benchmark:retrieval-competitive": "tsx scripts/competitive-retrieval-benchmark.ts",
    "benchmark:retrieval-paper": "tsx scripts/paper-retrieval-benchmark.ts",
    "benchmark:retrieval-splits": "tsx scripts/prepare-retrieval-splits.ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.15",
    "typescript": "^5.3.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "cli-truncate": "^6.0.0",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "figures": "^6.1.0",
    "highlight.js": "^11.11.1",
    "ink": "^7.0.3",
    "ink-text-input": "^6.0.0",
    "inquirer": "^14.0.2",
    "js-tiktoken": "^1.0.21",
    "marked": "^18.0.4",
    "react": "^19.2.6",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "tsx": "^4.22.2",
    "undici": "^7.28.0"
  }
}
