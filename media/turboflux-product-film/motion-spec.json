{
  "version": "2.1",
  "composition": {"id": "TurboFluxProductFilm", "width": 1920, "height": 1080, "fps": 30, "duration": 78},
  "brand": {
    "background": "#F5F5F2",
    "foreground": "#11110F",
    "dark": "#080807",
    "accent": "#EE5A36",
    "success": "#9ED2A8",
    "muted": "#777771",
    "safeArea": {"x": 150, "y": 90}
  },
  "motion": {
    "curves": {
      "heroEnter": [0.16, 1, 0.3, 1],
      "heroExit": [0.7, 0, 0.84, 0],
      "cameraGlide": [0.65, 0, 0.35, 1],
      "microUI": [0.2, 0.8, 0.2, 1],
      "editorial": [0.45, 0, 0.55, 1]
    },
    "minimumReadHold": 1.0
  },
  "audio": {"music": "public/audio/turboflux-score.mp3", "targetLufs": -18, "targetLra": 7, "style": "air, mechanical detail and sparse impacts without melody"},
  "narrativeGraph": {
    "nodes": [
      {"id": "brand-defined", "kind": "state"},
      {"id": "intent-submitted", "kind": "event"},
      {"id": "evidence-ranked", "kind": "result"},
      {"id": "execution-approved", "kind": "event"},
      {"id": "change-verified", "kind": "result"},
      {"id": "continuity-restored", "kind": "result"},
      {"id": "model-controlled", "kind": "state"},
      {"id": "promise-resolved", "kind": "result"}
    ],
    "edges": [
      {"from": "brand-defined", "to": "intent-submitted", "cause": "the promise resolves into the input surface", "transition": "match-cut"},
      {"from": "intent-submitted", "to": "evidence-ranked", "cause": "submission extends the activity line into evidence", "transition": "shared-element"},
      {"from": "evidence-ranked", "to": "execution-approved", "cause": "the top source path becomes the edit target", "transition": "shared-element"},
      {"from": "execution-approved", "to": "change-verified", "cause": "approval unlocks patching and verification", "transition": "status-change"},
      {"from": "change-verified", "to": "continuity-restored", "cause": "the verified rule becomes the history timeline", "transition": "match-cut"},
      {"from": "continuity-restored", "to": "model-controlled", "cause": "the restored command surface clears into controls", "transition": "shared-element"},
      {"from": "model-controlled", "to": "promise-resolved", "cause": "the selection rule becomes the closing baseline", "transition": "shared-element"}
    ]
  },
  "shots": [
    {
      "id": "brand-defined", "type": "brand-mark", "start": 0, "duration": 9,
      "purpose": "Define the product before showing the interface", "focus": "brand-and-promise",
      "entryCause": "the film opens in silence on the product mark", "exitCause": "the promise creates a need for a task input",
      "components": [{"id": "brand-mark", "kind": "brand-mark", "enter": {"at": 0.45, "duration": 1.1, "ease": "heroEnter"}, "hold": {"duration": 1.6}, "exit": {"at": 5, "duration": 0.55, "ease": "heroExit"}}],
      "events": [{"at": 2.4, "type": "brand.name", "target": "TurboFlux"}, {"at": 5.45, "type": "claim.reveal", "target": "product-promise"}],
      "transitionOut": {"kind": "match-cut", "element": "white-negative-space", "reason": "the brand field becomes the input field"},
      "audio": [{"at": 0.45, "cue": "soft-mark"}, {"at": 5.45, "cue": "paper-impact"}]
    },
    {
      "id": "intent-submitted", "type": "product-composer", "start": 9, "duration": 13,
      "purpose": "Show a real multimodal engineering task entering TurboFlux", "focus": "composer",
      "entryCause": "the white brand field becomes the empty composer", "exitCause": "submission starts background retrieval",
      "components": [{"id": "composer", "kind": "product-composer", "enter": {"at": 0.35, "duration": 0.9, "ease": "heroEnter"}, "hold": {"duration": 6.8}, "emphasis": {"at": 8.45, "duration": 0.35, "ease": "microUI"}, "exit": {"at": 12.35, "duration": 0.55, "ease": "heroExit"}}],
      "events": [{"at": 1.3, "type": "attachment.add", "target": "composer", "value": "architecture.png"}, {"at": 2, "type": "text.input", "target": "composer", "value": "读透 FastContext 调度链，修复漏检入口文件的问题，并跑完回归测试。"}, {"at": 8.45, "type": "keyboard.enter", "target": "composer"}, {"at": 8.66, "type": "status.start", "target": "fastcontext"}],
      "transitionOut": {"kind": "shared-element", "element": "activity-line", "reason": "the composer activity line becomes the evidence baseline"},
      "audio": [{"at": 2, "cue": "typing"}, {"at": 8.45, "cue": "submit"}, {"at": 8.66, "cue": "retrieval-start"}]
    },
    {
      "id": "evidence-ranked", "type": "shared-ui-close-up", "start": 22, "duration": 9,
      "purpose": "Prove retrieval with real TurboFlux source paths", "focus": "ranked-evidence",
      "entryCause": "the submitted task creates an evidence baseline", "exitCause": "the highest-ranked path becomes the edit target",
      "events": [{"at": 3.9, "type": "evidence.rank", "target": "fastContextSubagent.ts"}, {"at": 4.58, "type": "evidence.rank", "target": "agentEngine.ts"}, {"at": 5.26, "type": "evidence.rank", "target": "fastContextTypes.ts"}, {"at": 5.94, "type": "evidence.rank", "target": "fastContextUi.ts"}, {"at": 7.2, "type": "status.confirm", "target": "evidence-ready"}],
      "transitionOut": {"kind": "shared-element", "element": "fastContextSubagent-path", "reason": "the top path docks into the work area"},
      "audio": [{"at": 2.55, "cue": "dark-rise"}, {"at": 3.9, "cue": "evidence-tick"}, {"at": 7.2, "cue": "evidence-ready"}]
    },
    {
      "id": "execution-approved", "type": "product-stage", "start": 31, "duration": 13,
      "purpose": "Show retrieval, task state, approval and editing in one workflow", "focus": "scoped-approval",
      "entryCause": "the top-ranked path becomes the active source file", "exitCause": "approval produces a visible patch result",
      "events": [{"at": 4.4, "type": "approval.open", "target": "edit-file"}, {"at": 6.2, "type": "keyboard.arrow-down", "target": "allow-task"}, {"at": 7.3, "type": "keyboard.enter", "target": "allow-task"}, {"at": 7.9, "type": "status.start", "target": "edit-file"}, {"at": 9.2, "type": "status.confirm", "target": "patch-applied"}],
      "transitionOut": {"kind": "status-change", "element": "patch-applied", "reason": "the patch result opens into its diff"},
      "audio": [{"at": 0.25, "cue": "product-stage"}, {"at": 4.4, "cue": "approval-open"}, {"at": 7.3, "cue": "approval-confirm"}, {"at": 9.2, "cue": "patch-applied"}]
    },
    {
      "id": "change-verified", "type": "generated-outcome", "start": 44, "duration": 12,
      "purpose": "Prove that the edit passes engineering validation", "focus": "diff-and-tests",
      "entryCause": "the applied patch becomes a readable diff", "exitCause": "the verified rule extends into history",
      "events": [{"at": 1.15, "type": "diff.reveal", "target": "fastContextSubagent.ts"}, {"at": 5.4, "type": "command.complete", "target": "typecheck"}, {"at": 7.25, "type": "command.start", "target": "tests"}, {"at": 9.45, "type": "status.confirm", "target": "verified"}],
      "transitionOut": {"kind": "match-cut", "element": "verified-rule", "reason": "the verification rule becomes the conversation timeline"},
      "audio": [{"at": 4.4, "cue": "camera-travel"}, {"at": 5.4, "cue": "typecheck-pass"}, {"at": 9.45, "cue": "verified"}]
    },
    {
      "id": "continuity-restored", "type": "before-after", "start": 56, "duration": 9,
      "purpose": "Show compaction preserving task continuity", "focus": "recap-and-resume",
      "entryCause": "the verified rule becomes a conversation timeline", "exitCause": "resume restores the task state",
      "events": [{"at": 3, "type": "context.compact", "target": "history"}, {"at": 5.25, "type": "text.input", "target": "command", "value": "/resume fastcontext-fix"}, {"at": 6.4, "type": "status.confirm", "target": "restored-state"}],
      "transitionOut": {"kind": "shared-element", "element": "command-surface", "reason": "the restored command surface clears into model controls"},
      "audio": [{"at": 3, "cue": "compact"}, {"at": 5.25, "cue": "resume"}, {"at": 6.4, "cue": "restore"}]
    },
    {
      "id": "model-controlled", "type": "shared-ui-close-up", "start": 65, "duration": 6,
      "purpose": "Show API model discovery and model-native effort", "focus": "model-controls",
      "entryCause": "the restored command surface becomes the model command list", "exitCause": "the selected effort rule becomes the closing baseline",
      "events": [{"at": 0.4, "type": "command.open", "target": "model"}, {"at": 2.05, "type": "command.open", "target": "effort"}, {"at": 3.5, "type": "keyboard.enter", "target": "high"}],
      "transitionOut": {"kind": "shared-element", "element": "selection-rule", "reason": "the effort underline becomes the brand baseline"},
      "audio": [{"at": 0.4, "cue": "control-open"}, {"at": 3.5, "cue": "control-select"}]
    },
    {
      "id": "promise-resolved", "type": "end-card", "start": 71, "duration": 7,
      "purpose": "Resolve the film on the product promise", "focus": "brand-and-claim",
      "entryCause": "the model selection rule redraws the brand baseline", "exitCause": "the film holds on the resolved promise",
      "events": [{"at": 1, "type": "brand.reveal", "target": "TurboFlux"}, {"at": 2.3, "type": "claim.reveal", "target": "从意图，到验证。"}],
      "transitionOut": {"kind": "hard-cut", "element": "end", "reason": "the finished promise ends the film"},
      "audio": [{"at": 1, "cue": "brand-return"}, {"at": 2.3, "cue": "final-claim"}]
    }
  ]
}
