TURBOFLUX_SERVER_HOST=127.0.0.1
TURBOFLUX_SERVER_PORT=8787
TURBOFLUX_SERVER_CONFIG=.turboflux/server-config.json

# Backend-only upstream credentials. Do not put this key in CLI config or UI code.
TURBOFLUX_FREE_MODEL_API_KEY=
TURBOFLUX_FREE_MODEL_BASE_URL=https://api.deepseek.com/v1
TURBOFLUX_FREE_MODEL=deepseek-v4-flash
TURBOFLUX_CORS_ORIGIN=http://127.0.0.1

# Optional: set this if the backend is exposed beyond localhost.
# The CLI apiKey and admin page token must match this token when enabled.
TURBOFLUX_PROXY_AUTH_TOKEN=
